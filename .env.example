# Copy to .env and fill in. NEVER commit .env.

# --- Trading mode: "dry_run" (simulate/paper, no live orders) or "live" ---
TRADING_MODE=dry_run

# --- Alpaca (https://app.alpaca.markets) ---
# Single-fund setup (no funds.json): these keys are the "default" fund.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# true = paper account endpoint, false = live account endpoint
ALPACA_PAPER=true

# Multi-fund setup: copy funds.example.json to funds.json, and define one env
# key pair per fund here with whatever names funds.json references, e.g.:
# ALPACA_PAPER_KEY=
# ALPACA_PAPER_SECRET=
# ALPACA_LIVE_KEY=
# ALPACA_LIVE_SECRET=

# --- Notifications ---
# macOS notification center alerts (orders, halts, failures)
NOTIFY_MACOS=true
# Optional: also post the same alerts to a Discord webhook
DISCORD_WEBHOOK_URL=

# --- Quiver Quantitative (https://api.quiverquant.com) ---
QUIVER_API_KEY=

# --- Congress.gov API (bills and committee activity; free key) ---
CONGRESS_GOV_API_KEY=

# --- Anthropic / Claude (sentiment classification) ---
ANTHROPIC_API_KEY=

# --- SEC EDGAR (ticker → company/sector metadata; free, no key) ---
# SEC asks for a contact email in the User-Agent of automated requests
SEC_CONTACT_EMAIL=

# --- Risk limits (safety rails) ---
MAX_TRADE_NOTIONAL_USD=100
MAX_TRADE_PCT_EQUITY=2
MAX_OPEN_POSITIONS=10
MAX_TOTAL_EXPOSURE_USD=1000
MAX_DAILY_LOSS_USD=50
MAX_DAILY_LOSS_PCT=2

# --- Signal thresholds ---
SENTIMENT_CONFIDENCE_THRESHOLD=0.8
# Require this post-level market relevance before sentiment signals are emitted
SENTIMENT_MIN_RELEVANCE=0.5
# Reject congress signals disclosed more than this many days ago
CONGRESS_MAX_DISCLOSURE_AGE_DAYS=3
# Optional: minimum persisted copy-worthiness score for congress signals.
# Empty disables score gating and preserves the default pipeline behavior.
CONGRESS_MIN_COPY_SCORE=
# "legacy" preserves direct congress signal creation; "strategies" routes new
# congress trades through the Phase 9 strategy engine instead.
SIGNAL_ROUTING=legacy
# Manual strategy approvals expire after this many hours.
APPROVAL_TTL_HOURS=24
# Reject sentiment signals for posts older than this many minutes
SENTIMENT_MAX_POST_AGE_MINUTES=15

# --- Polling ---
CONGRESS_POLL_CRON=*/20 * * * *
YOUTUBE_POLL_CRON=*/30 * * * *
TRUTH_SOCIAL_POLL_SECONDS=30
# Truth Social user to watch
TRUTH_SOCIAL_USERNAME=realDonaldTrump

# --- YouTube finfluencer ingestion ---
# Official YouTube Data API v3 key (channel/video metadata, playlists)
YOUTUBE_API_KEY=
# Automated caption fetching via yt-dlp is a YouTube ToS gray area; it stays
# OFF until you explicitly opt in. Documents it creates are stamped
# authorization_status=auto_captions_tos_gray so provenance is always queryable.
YOUTUBE_AUTO_TRANSCRIPTS_ENABLED=false
YT_DLP_PATH=yt-dlp
# Stop retrying a video's transcript after this many failed attempts
YOUTUBE_TRANSCRIPT_MAX_ATTEMPTS=3
# Minimum delay between yt-dlp fetches (politeness / rate limiting)
YOUTUBE_TRANSCRIPT_FETCH_DELAY_MS=5000
# Per-poll caps bound YouTube API quota and LLM classification spend
YOUTUBE_POLL_MAX_VIDEOS_PER_RUN=10
YOUTUBE_BACKFILL_MAX_PER_RUN=5
# Seed tracked channels from server/lib/youtubeRoster.json at startup
YOUTUBE_ROSTER_SEED_ENABLED=true

# --- Claude model for sentiment classification ---
SENTIMENT_MODEL=claude-haiku-4-5-20251001

# --- Morning digest ---
# Weekday morning brief: overnight creator mentions, high-score congress
# trades, cross-source confluence, and pump warnings on held positions.
DIGEST_ENABLED=true
DIGEST_CRON=30 7 * * 1-5
DIGEST_CHANNEL=all
DIGEST_MIN_COPY_SCORE=70

# --- Thesis cards ---
# Cards are deterministic and free by default. Set THESIS_LLM=true to also rewrite
# each card into a short analyst note via Claude (falls back silently on any error).
THESIS_LLM=false
THESIS_MODEL=claude-haiku-4-5-20251001

# --- Server ---
PORT=3000
