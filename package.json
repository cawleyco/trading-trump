{
  "name": "trading-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Personal automated trading bot: congressional trade copying + Trump post sentiment signals",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "build:client": "npm --prefix client run build",
    "dev:client": "npm --prefix client run dev",
    "backfill": "node scripts/backfill-congress.js",
    "test": "node --test 'test/**/*.test.js'"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@anthropic-ai/sdk": "^0.110.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.6.0",
    "p-retry": "^8.0.0",
    "yaml": "^2.9.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
